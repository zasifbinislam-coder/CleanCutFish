NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Server-only — DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Payments (sandbox to start) ---
BKASH_APP_KEY=
BKASH_APP_SECRET=
